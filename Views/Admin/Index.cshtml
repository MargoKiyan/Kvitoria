@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Адмін-панель";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Адміністрування</p>
        <h1>Панель адміністратора</h1>
        <p class="heading-copy">Доступ до всієї бази даних, статистики, звернень і звітів.</p>
    </div>
    <div class="heading-actions">
        <a class="btn btn-primary" asp-action="Reports">Звіти</a>
        <a class="btn btn-outline-secondary" asp-action="Feedback">Звернення</a>
    </div>
</section>

<section class="metric-grid admin-summary-grid">
    <article class="metric-card">
        <span>Користувачі</span>
        <strong>@Model.RegisteredUsers</strong>
    </article>
    <article class="metric-card">
        <span>Активні</span>
        <strong>@Model.ActiveUsers</strong>
    </article>
    <article class="metric-card accent">
        <span>Видалені</span>
        <strong>@Model.DeletedUsers</strong>
    </article>
    <article class="metric-card">
        <span>Види рослин</span>
        <strong>@Model.PlantSpeciesCount</strong>
    </article>
    <article class="metric-card">
        <span>Форми/сорти</span>
        <strong>@Model.PlantVarietiesCount</strong>
    </article>
</section>

<div class="admin-grid">
    <a class="surface admin-tile" asp-action="Users">
        <strong>Користувачі</strong>
        <span>Перегляд, деактивація, відновлення.</span>
    </a>
    <a class="surface admin-tile" asp-action="Plants">
        <strong>Рослини</strong>
        <span>Каталог видів, форм і сортів для вибору користувачами.</span>
    </a>
    <a class="surface admin-tile" asp-action="Feedback">
        <strong>Зворотній зв'язок</strong>
        <span>@Model.FeedbackUnreadCount непрочитаних звернень.</span>
    </a>
    <a class="surface admin-tile" asp-action="Reports">
        <strong>Генерація звітів</strong>
        <span>TXT через FileIO та Word .docx.</span>
    </a>
</div>

<section class="surface mt-4">
    <div class="section-title">
        <div>
            <p class="eyebrow">Поточна інформація</p>
            <h2>Метрики бази даних</h2>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table align-middle">
            <tbody>
                @foreach (var metric in Model.Metrics)
                {
                    <tr>
                        <th>@metric.Name</th>
                        <td>@metric.Value.ToString("0.##")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
