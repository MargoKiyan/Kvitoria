@{
    ViewData["Title"] = "Звіти";
}

<section class="surface narrow">
    <p class="eyebrow"><i class="fa-regular fa-file-lines" aria-hidden="true"></i> FileIO</p>
    <h1>Генерація звітів</h1>
    <p>Звіти містять поточну статистику користувачів, рослин, звернень і повідомлень.</p>
    <div class="form-actions">
        <form asp-action="GenerateTextReport" method="post">
            <button class="btn btn-primary" type="submit">TXT звіт</button>
        </form>
        <form asp-action="GenerateWordReport" method="post">
            <button class="btn btn-outline-secondary" type="submit">Word .docx звіт</button>
        </form>
        <a class="btn btn-outline-secondary" asp-action="Index">Назад</a>
    </div>
</section>
