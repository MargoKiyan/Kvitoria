@model PaginationViewModel

@if (Model.TotalItems > Model.PageSize)
{
    <nav class="pagination-block surface" aria-label="Пагінація">
        <div class="pagination-summary">
            Показано @Model.FirstItemNumber-@Model.LastItemNumber з @Model.TotalItems
        </div>
        <ul class="pagination-list">
            <li>
                @if (Model.HasPreviousPage)
                {
                    <a class="pagination-link" asp-action="@Model.Action" asp-all-route-data="@Model.GetRouteValues(Model.CurrentPage - 1)" aria-label="Попередня сторінка">
                        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    </a>
                }
                else
                {
                    <span class="pagination-link is-disabled" aria-hidden="true">
                        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
                    </span>
                }
            </li>
            @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
            {
                <li>
                    @if (pageNumber == Model.CurrentPage)
                    {
                        <span class="pagination-link is-active" aria-current="page">@pageNumber</span>
                    }
                    else
                    {
                        <a class="pagination-link" asp-action="@Model.Action" asp-all-route-data="@Model.GetRouteValues(pageNumber)">@pageNumber</a>
                    }
                </li>
            }
            <li>
                @if (Model.HasNextPage)
                {
                    <a class="pagination-link" asp-action="@Model.Action" asp-all-route-data="@Model.GetRouteValues(Model.CurrentPage + 1)" aria-label="Наступна сторінка">
                        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                    </a>
                }
                else
                {
                    <span class="pagination-link is-disabled" aria-hidden="true">
                        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
                    </span>
                }
            </li>
        </ul>
    </nav>
}
